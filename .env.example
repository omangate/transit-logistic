# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://transit:transit_secret@localhost:5432/transit_logistic?schema=public"

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
NODE_ENV=development

# ── Web ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ── Auth (Phase 1) ──────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-too
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Transit Logistic <noreply@transit-logistic.dev>
WEB_APP_URL=http://127.0.0.1:3000

# ── Payments ────────────────────────────────────────────────────────────────
# Providers: thawani | myfatoorah | stripe | mock
PAYMENT_PROVIDER=mock
THAWANI_SECRET_KEY=
THAWANI_PUBLISHABLE_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
