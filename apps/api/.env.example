DATABASE_URL="postgresql://transit:transit_secret@localhost:5432/transit_logistic?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

API_PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://your-domain.com
WEB_APP_URL=https://your-domain.com

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-48-byte-random-secret
JWT_REFRESH_SECRET=replace-with-48-byte-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

TRACKING_GEOFENCE_RADIUS_M=500
TRACKING_LIVE_CACHE_TTL_S=86400

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Transit Logistic <noreply@your-domain.com>"

# Payments: mock | thawani | myfatoorah | stripe
PAYMENT_PROVIDER=thawani
THAWANI_SECRET_KEY=
THAWANI_PUBLISHABLE_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
