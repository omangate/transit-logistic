{
  "name": "@transit-logistic/api",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm db:generate && rimraf dist tsconfig.build.tsbuildinfo && nest build",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "prestart": "pnpm db:generate",
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "start:prod": "prisma migrate deploy --schema=./prisma/schema.prisma && node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest && jest --config test/jest-e2e.json --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.1",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/client": "^6.8.2",
    "@transit-logistic/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.5.1",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "prisma": "^6.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.26",
    "@transit-logistic/eslint-config": "workspace:*",
    "@transit-logistic/tsconfig": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.21",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.27.0",
    "jest": "^30.4.2",
    "rimraf": "^6.0.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
