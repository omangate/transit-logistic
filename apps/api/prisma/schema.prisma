// Transit Logistic — MVP database schema (approved architecture)
// Phase 0: schema definition + migration tooling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  customer
  fleet_owner
  driver
  admin

  @@map("user_role")
}

enum Locale {
  en
  ar

  @@map("locale")
}

enum KycStatus {
  not_submitted
  pending
  approved
  rejected

  @@map("kyc_status")
}

enum ShipmentStatus {
  draft
  pending_assignment
  assigned
  picked_up
  in_transit
  delivered
  completed
  cancelled

  @@map("shipment_status")
}

enum WalletTransactionType {
  top_up
  shipment_payment
  platform_fee
  payout
  refund
  adjustment

  @@map("wallet_tx_type")
}

enum PayoutRequestStatus {
  pending
  approved
  rejected
  processed

  @@map("payout_request_status")
}

enum DocumentStatus {
  pending
  approved
  rejected

  @@map("document_status")
}

enum VehicleType {
  flatbed
  refrigerated
  container
  tanker
  other

  @@map("vehicle_type")
}

enum NotificationChannel {
  in_app
  push
  email

  @@map("notification_channel")
}

enum PaymentStatus {
  requires_payment_method
  requires_confirmation
  processing
  succeeded
  failed
  cancelled
  refunded

  @@map("payment_status")
}

enum PaymentProviderType {
  mock
  stripe
  tap
  thawani
  myfatoorah

  @@map("payment_provider_type")
}

enum CargoType {
  dry
  refrigerated
  special

  @@map("cargo_type")
}

enum ShippingMethod {
  standard
  express
  cross_border

  @@map("shipping_method")
}

// ── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  phone        String?   @unique
  passwordHash String    @map("password_hash")
  role         UserRole
  locale       Locale    @default(en)
  isActive     Boolean   @default(true) @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens      RefreshToken[]
  customerProfile    CustomerProfile?
  fleetOwner         FleetOwner?
  driverProfile      DriverProfile?
  addresses          Address[]
  shipmentsCreated   Shipment[]           @relation("ShipmentCustomer")
  shipmentsAssigned  Shipment[]           @relation("ShipmentDriver")
  wallet             Wallet?
  notifications      Notification[]
  deviceTokens       DeviceToken[]
  auditLogs          AuditLog[]
  payoutRequests     PayoutRequest[]
  reviewedPayouts    PayoutRequest[]      @relation("PayoutReviewer")
  shipmentEvents     ShipmentEvent[]
  statusHistory      ShipmentStatusHistory[]
  paymentIntents     PaymentIntent[]
  carrierRatings     CarrierRating[]      @relation("RatingCustomer")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  fullName  String   @map("full_name")
  company   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

// ── Fleet ───────────────────────────────────────────────────────────────────

model FleetOwner {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  companyName String  @map("company_name")
  taxId     String?   @map("tax_id")
  kycStatus KycStatus @default(not_submitted) @map("kyc_status")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  FleetOwnerDocument[]
  vehicles   Vehicle[]
  drivers    DriverProfile[]
  shipments  Shipment[]
  ratings    CarrierRating[]

  @@map("fleet_owners")
}

model FleetOwnerDocument {
  id           String         @id @default(uuid()) @db.Uuid
  fleetOwnerId String         @map("fleet_owner_id") @db.Uuid
  documentType String         @map("document_type")
  fileUrl      String         @map("file_url")
  status       DocumentStatus @default(pending)
  reviewedAt   DateTime?      @map("reviewed_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)

  @@index([fleetOwnerId])
  @@map("fleet_owner_documents")
}

model DriverProfile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  fleetOwnerId String   @map("fleet_owner_id") @db.Uuid
  licenseNumber String  @map("license_number")
  isAvailable  Boolean  @default(true) @map("is_available")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id])

  @@index([fleetOwnerId])
  @@map("driver_profiles")
}

model Vehicle {
  id           String      @id @default(uuid()) @db.Uuid
  fleetOwnerId String      @map("fleet_owner_id") @db.Uuid
  plateNumber  String      @map("plate_number")
  vehicleType  VehicleType @map("vehicle_type")
  capacityKg   Decimal?    @map("capacity_kg") @db.Decimal(10, 2)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  fleetOwner FleetOwner        @relation(fields: [fleetOwnerId], references: [id])
  documents  VehicleDocument[]
  shipments  Shipment[]

  @@unique([fleetOwnerId, plateNumber])
  @@map("vehicles")
}

model VehicleDocument {
  id           String         @id @default(uuid()) @db.Uuid
  vehicleId    String         @map("vehicle_id") @db.Uuid
  documentType String         @map("document_type")
  fileUrl      String         @map("file_url")
  status       DocumentStatus @default(pending)
  expiresAt    DateTime?      @map("expires_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_documents")
}

// ── Addresses ───────────────────────────────────────────────────────────────

model Address {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String?
  line1     String
  line2     String?
  city      String
  region    String?
  country   String   @default("SA")
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ── Shipments ───────────────────────────────────────────────────────────────

model Shipment {
  id              String         @id @default(uuid()) @db.Uuid
  referenceNumber String         @unique @map("reference_number")
  customerId      String         @map("customer_id") @db.Uuid
  fleetOwnerId    String?        @map("fleet_owner_id") @db.Uuid
  driverId        String?        @map("driver_id") @db.Uuid
  vehicleId       String?        @map("vehicle_id") @db.Uuid
  status          ShipmentStatus @default(draft)
  cargoType       CargoType      @default(dry) @map("cargo_type")
  cargoDescription String?       @map("cargo_description")
  weightKg        Decimal?       @map("weight_kg") @db.Decimal(10, 2)
  packageCount    Int?           @map("package_count")
  lengthCm        Decimal?       @map("length_cm") @db.Decimal(10, 2)
  widthCm         Decimal?       @map("width_cm") @db.Decimal(10, 2)
  heightCm        Decimal?       @map("height_cm") @db.Decimal(10, 2)
  shippingMethod  ShippingMethod @default(standard) @map("shipping_method")
  isCrossBorder   Boolean        @default(false) @map("is_cross_border")
  scheduledAt     DateTime?      @map("scheduled_at")
  pickedUpAt      DateTime?      @map("picked_up_at")
  deliveredAt     DateTime?      @map("delivered_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  customer         User                    @relation("ShipmentCustomer", fields: [customerId], references: [id])
  fleetOwner       FleetOwner?             @relation(fields: [fleetOwnerId], references: [id])
  driver           User?                   @relation("ShipmentDriver", fields: [driverId], references: [id])
  vehicle          Vehicle?                @relation(fields: [vehicleId], references: [id])
  stops            ShipmentStop[]
  documents        ShipmentDocument[]
  statusHistory    ShipmentStatusHistory[]
  events           ShipmentEvent[]
  priceCalculation PriceCalculation?
  trackingPoints   TrackingPoint[]
  geofenceEvents   GeofenceEvent[]
  paymentIntents   PaymentIntent[]
  contract         ShipmentContract?
  invoice          ShipmentInvoice?
  rating           CarrierRating?

  @@index([customerId])
  @@index([fleetOwnerId])
  @@index([status])
  @@map("shipments")
}

model ShipmentStop {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  sequence   Int
  address    String
  city       String
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  stopType   String   @map("stop_type")
  arrivedAt  DateTime? @map("arrived_at")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, sequence])
  @@map("shipment_stops")
}

model ShipmentDocument {
  id           String   @id @default(uuid()) @db.Uuid
  shipmentId   String   @map("shipment_id") @db.Uuid
  documentType String   @map("document_type")
  fileUrl      String   @map("file_url")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_documents")
}

model ShipmentContract {
  id             String   @id @default(uuid()) @db.Uuid
  shipmentId     String   @unique @map("shipment_id") @db.Uuid
  contractNumber String   @unique @map("contract_number")
  termsVersion   String   @default("1.0") @map("terms_version")
  signedAt       DateTime @map("signed_at")
  payload        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_contracts")
}

model ShipmentInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  shipmentId      String   @unique @map("shipment_id") @db.Uuid
  invoiceNumber   String   @unique @map("invoice_number")
  paymentIntentId String?  @map("payment_intent_id") @db.Uuid
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("SAR")
  issuedAt        DateTime @map("issued_at")
  payload         Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_invoices")
}

model CarrierRating {
  id           String   @id @default(uuid()) @db.Uuid
  shipmentId   String   @unique @map("shipment_id") @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  fleetOwnerId String   @map("fleet_owner_id") @db.Uuid
  score        Int
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  shipment   Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customer   User       @relation("RatingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)

  @@index([fleetOwnerId])
  @@map("carrier_ratings")
}

model ShipmentStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  shipmentId String         @map("shipment_id") @db.Uuid
  fromStatus ShipmentStatus? @map("from_status")
  toStatus   ShipmentStatus @map("to_status")
  actorId    String?        @map("actor_id") @db.Uuid
  note       String?
  createdAt  DateTime       @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorId], references: [id])

  @@index([shipmentId])
  @@map("shipment_status_history")
}

model ShipmentEvent {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  eventType  String   @map("event_type")
  payload    Json     @default("{}")
  actorId    String?  @map("actor_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorId], references: [id])

  @@index([shipmentId, createdAt])
  @@index([eventType])
  @@map("shipment_events")
}

// ── Pricing ─────────────────────────────────────────────────────────────────

model PricingRule {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  nameAr      String?  @map("name_ar")
  ruleType    String   @map("rule_type")
  config      Json
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  calculations PriceCalculation[]

  @@map("pricing_rules")
}

model PriceCalculation {
  id             String   @id @default(uuid()) @db.Uuid
  shipmentId     String   @unique @map("shipment_id") @db.Uuid
  pricingRuleId  String?  @map("pricing_rule_id") @db.Uuid
  baseAmount     Decimal  @map("base_amount") @db.Decimal(12, 2)
  platformFee    Decimal  @map("platform_fee") @db.Decimal(12, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  currency       String   @default("SAR")
  breakdown      Json     @default("{}")
  calculatedAt   DateTime @default(now()) @map("calculated_at")

  shipment    Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  pricingRule PricingRule? @relation(fields: [pricingRuleId], references: [id])

  @@map("price_calculations")
}

// ── Payments ────────────────────────────────────────────────────────────────

model PaymentIntent {
  id               String              @id @default(uuid()) @db.Uuid
  shipmentId       String              @map("shipment_id") @db.Uuid
  customerId       String              @map("customer_id") @db.Uuid
  amount           Decimal             @db.Decimal(12, 2)
  currency         String              @default("SAR")
  status           PaymentStatus       @default(requires_confirmation)
  provider         PaymentProviderType @default(mock)
  providerIntentId String?             @unique @map("provider_intent_id")
  clientSecret     String?             @map("client_secret")
  metadata         Json                @default("{}")
  failureCode      String?             @map("failure_code")
  failureMessage   String?             @map("failure_message")
  confirmedAt      DateTime?           @map("confirmed_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  shipment Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customer User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events   PaymentEvent[]

  @@index([shipmentId])
  @@index([customerId])
  @@index([status])
  @@map("payment_intents")
}

model PaymentEvent {
  id              String   @id @default(uuid()) @db.Uuid
  paymentIntentId String   @map("payment_intent_id") @db.Uuid
  eventType       String   @map("event_type")
  payload         Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([paymentIntentId, createdAt])
  @@map("payment_events")
}

// ── Wallets ─────────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("SAR")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  payoutRequests PayoutRequest[]

  @@map("wallets")
}

model WalletTransaction {
  id             String                @id @default(uuid()) @db.Uuid
  walletId       String                @map("wallet_id") @db.Uuid
  type           WalletTransactionType
  amount         Decimal               @db.Decimal(14, 2)
  balanceAfter   Decimal               @map("balance_after") @db.Decimal(14, 2)
  referenceType  String?               @map("reference_type")
  referenceId    String?               @map("reference_id") @db.Uuid
  idempotencyKey String                @unique @map("idempotency_key")
  description    String?
  createdAt      DateTime              @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model PayoutRequest {
  id                  String              @id @default(uuid()) @db.Uuid
  walletId            String              @map("wallet_id") @db.Uuid
  userId              String              @map("user_id") @db.Uuid
  amount              Decimal             @db.Decimal(14, 2)
  currency            String              @default("SAR")
  bankDetails         Json                @map("bank_details")
  status              PayoutRequestStatus @default(pending)
  reviewedById        String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt          DateTime?           @map("reviewed_at")
  rejectionReason     String?             @map("rejection_reason")
  walletTransactionId String?             @map("wallet_transaction_id") @db.Uuid
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  wallet     Wallet @relation(fields: [walletId], references: [id])
  user       User   @relation(fields: [userId], references: [id])
  reviewedBy User?  @relation("PayoutReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payout_requests")
}

// ── Tracking ────────────────────────────────────────────────────────────────

model TrackingPoint {
  id         BigInt   @id @default(autoincrement())
  shipmentId String   @map("shipment_id") @db.Uuid
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  speed      Decimal? @db.Decimal(6, 2)
  heading    Decimal? @db.Decimal(5, 2)
  recordedAt DateTime @map("recorded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, recordedAt])
  @@map("tracking_points")
}

model GeofenceEvent {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  eventType  String   @map("event_type")
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("geofence_events")
}

// ── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  titleEn   String              @map("title_en")
  titleAr   String              @map("title_ar")
  bodyEn    String              @map("body_en")
  bodyAr    String              @map("body_ar")
  data      Json                @default("{}")
  isRead    Boolean             @default(false) @map("is_read")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ── Platform ────────────────────────────────────────────────────────────────

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
