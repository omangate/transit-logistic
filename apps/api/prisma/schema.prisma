// Transit Logistic — MVP database schema (approved architecture)
// Phase 0: schema definition + migration tooling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  customer
  fleet_owner
  driver
  admin

  @@map("user_role")
}

enum Locale {
  en
  ar

  @@map("locale")
}

enum KycStatus {
  not_submitted
  pending
  approved
  rejected

  @@map("kyc_status")
}

enum ShipmentStatus {
  draft
  pending_assignment
  assigned
  picked_up
  in_transit
  delivered
  completed
  cancelled

  @@map("shipment_status")
}

enum WalletTransactionType {
  top_up
  shipment_payment
  platform_fee
  payout
  refund
  adjustment

  @@map("wallet_tx_type")
}

enum PayoutRequestStatus {
  pending
  approved
  rejected
  processed

  @@map("payout_request_status")
}

enum DocumentStatus {
  pending
  approved
  rejected

  @@map("document_status")
}

enum VehicleType {
  flatbed
  refrigerated
  container
  tanker
  other

  @@map("vehicle_type")
}

enum NotificationChannel {
  in_app
  push
  email

  @@map("notification_channel")
}

enum PaymentStatus {
  requires_payment_method
  requires_confirmation
  processing
  succeeded
  failed
  cancelled
  refunded

  @@map("payment_status")
}

enum PaymentProviderType {
  mock
  stripe
  tap
  thawani
  myfatoorah

  @@map("payment_provider_type")
}

enum CargoType {
  dry
  refrigerated
  special

  @@map("cargo_type")
}

enum ShippingMethod {
  standard
  express
  cross_border

  @@map("shipping_method")
}

enum VehicleCategory {
  light_truck
  medium_truck
  heavy_truck
  trailer
  van
  specialized

  @@map("vehicle_category")
}

enum TruckListingStatus {
  draft
  pending_approval
  approved
  rejected
  suspended

  @@map("truck_listing_status")
}

enum TruckAvailabilityStatus {
  available
  busy
  maintenance

  @@map("truck_availability_status")
}

enum QuoteRequestStatus {
  pending
  responded
  accepted
  declined
  expired

  @@map("quote_request_status")
}

enum GeoRegionType {
  governorate
  wilayat
  city
  industrial_area
  free_zone
  port

  @@map("geo_region_type")
}

enum ShipmentRequestStatus {
  open
  matched
  converted
  cancelled
  expired

  @@map("shipment_request_status")
}

// ── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  phone        String?   @unique
  passwordHash String    @map("password_hash")
  role         UserRole
  locale       Locale    @default(ar)
  isActive     Boolean   @default(true) @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens      RefreshToken[]
  customerProfile    CustomerProfile?
  fleetOwner         FleetOwner?
  driverProfile      DriverProfile?
  addresses          Address[]
  shipmentsCreated   Shipment[]           @relation("ShipmentCustomer")
  shipmentsAssigned  Shipment[]           @relation("ShipmentDriver")
  wallet             Wallet?
  notifications      Notification[]
  deviceTokens       DeviceToken[]
  auditLogs          AuditLog[]
  payoutRequests     PayoutRequest[]
  reviewedPayouts    PayoutRequest[]      @relation("PayoutReviewer")
  shipmentEvents     ShipmentEvent[]
  statusHistory      ShipmentStatusHistory[]
  paymentIntents     PaymentIntent[]
  carrierRatings     CarrierRating[]      @relation("RatingCustomer")
  truckQuoteRequests TruckQuoteRequest[]
  truckReviews       TruckReview[]        @relation("TruckReviewCustomer")
  shipmentRequests   ShipmentRequest[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model CustomerProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  fullName  String   @map("full_name")
  company   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

// ── Fleet ───────────────────────────────────────────────────────────────────

model FleetOwner {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  companyName String  @map("company_name")
  taxId     String?   @map("tax_id")
  kycStatus KycStatus @default(not_submitted) @map("kyc_status")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents  FleetOwnerDocument[]
  vehicles   Vehicle[]
  drivers    DriverProfile[]
  shipments  Shipment[]
  ratings    CarrierRating[]
  truckListings TruckListing[]
  truckReviews  TruckReview[]
  shipmentRequestMatches ShipmentRequestMatch[]

  @@map("fleet_owners")
}

model FleetOwnerDocument {
  id           String         @id @default(uuid()) @db.Uuid
  fleetOwnerId String         @map("fleet_owner_id") @db.Uuid
  documentType String         @map("document_type")
  fileUrl      String         @map("file_url")
  status       DocumentStatus @default(pending)
  reviewedAt   DateTime?      @map("reviewed_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)

  @@index([fleetOwnerId])
  @@map("fleet_owner_documents")
}

model DriverProfile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  fleetOwnerId String   @map("fleet_owner_id") @db.Uuid
  licenseNumber String  @map("license_number")
  isAvailable  Boolean  @default(true) @map("is_available")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id])

  @@index([fleetOwnerId])
  @@map("driver_profiles")
}

model Vehicle {
  id           String      @id @default(uuid()) @db.Uuid
  fleetOwnerId String      @map("fleet_owner_id") @db.Uuid
  plateNumber  String      @map("plate_number")
  vehicleType  VehicleType @map("vehicle_type")
  capacityKg   Decimal?    @map("capacity_kg") @db.Decimal(10, 2)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  fleetOwner FleetOwner        @relation(fields: [fleetOwnerId], references: [id])
  documents  VehicleDocument[]
  shipments  Shipment[]
  truckListing TruckListing?

  @@unique([fleetOwnerId, plateNumber])
  @@map("vehicles")
}

model VehicleDocument {
  id           String         @id @default(uuid()) @db.Uuid
  vehicleId    String         @map("vehicle_id") @db.Uuid
  documentType String         @map("document_type")
  fileUrl      String         @map("file_url")
  status       DocumentStatus @default(pending)
  expiresAt    DateTime?      @map("expires_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_documents")
}

// ── Addresses ───────────────────────────────────────────────────────────────

model Address {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String?
  line1     String
  line2     String?
  city      String
  region    String?
  country   String   @default("SA")
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ── Shipments ───────────────────────────────────────────────────────────────

model Shipment {
  id              String         @id @default(uuid()) @db.Uuid
  referenceNumber String         @unique @map("reference_number")
  customerId      String         @map("customer_id") @db.Uuid
  fleetOwnerId    String?        @map("fleet_owner_id") @db.Uuid
  driverId        String?        @map("driver_id") @db.Uuid
  vehicleId       String?        @map("vehicle_id") @db.Uuid
  truckListingId  String?        @map("truck_listing_id") @db.Uuid
  status          ShipmentStatus @default(draft)
  cargoType       CargoType      @default(dry) @map("cargo_type")
  cargoDescription String?       @map("cargo_description")
  weightKg        Decimal?       @map("weight_kg") @db.Decimal(10, 2)
  packageCount    Int?           @map("package_count")
  lengthCm        Decimal?       @map("length_cm") @db.Decimal(10, 2)
  widthCm         Decimal?       @map("width_cm") @db.Decimal(10, 2)
  heightCm        Decimal?       @map("height_cm") @db.Decimal(10, 2)
  shippingMethod  ShippingMethod @default(standard) @map("shipping_method")
  isCrossBorder   Boolean        @default(false) @map("is_cross_border")
  scheduledAt     DateTime?      @map("scheduled_at")
  pickedUpAt      DateTime?      @map("picked_up_at")
  deliveredAt     DateTime?      @map("delivered_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  customer         User                    @relation("ShipmentCustomer", fields: [customerId], references: [id])
  fleetOwner       FleetOwner?             @relation(fields: [fleetOwnerId], references: [id])
  driver           User?                   @relation("ShipmentDriver", fields: [driverId], references: [id])
  vehicle          Vehicle?                @relation(fields: [vehicleId], references: [id])
  truckListing     TruckListing?           @relation(fields: [truckListingId], references: [id])
  stops            ShipmentStop[]
  documents        ShipmentDocument[]
  statusHistory    ShipmentStatusHistory[]
  events           ShipmentEvent[]
  priceCalculation PriceCalculation?
  trackingPoints   TrackingPoint[]
  geofenceEvents   GeofenceEvent[]
  paymentIntents   PaymentIntent[]
  contract         ShipmentContract?
  invoice          ShipmentInvoice?
  rating           CarrierRating?

  @@index([customerId])
  @@index([fleetOwnerId])
  @@index([truckListingId])
  @@index([status])
  @@map("shipments")
}

model ShipmentStop {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  sequence   Int
  address    String
  city       String
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  stopType   String   @map("stop_type")
  arrivedAt  DateTime? @map("arrived_at")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, sequence])
  @@map("shipment_stops")
}

model ShipmentDocument {
  id           String   @id @default(uuid()) @db.Uuid
  shipmentId   String   @map("shipment_id") @db.Uuid
  documentType String   @map("document_type")
  fileUrl      String   @map("file_url")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_documents")
}

model ShipmentContract {
  id             String   @id @default(uuid()) @db.Uuid
  shipmentId     String   @unique @map("shipment_id") @db.Uuid
  contractNumber String   @unique @map("contract_number")
  termsVersion   String   @default("1.0") @map("terms_version")
  signedAt       DateTime @map("signed_at")
  payload        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_contracts")
}

model ShipmentInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  shipmentId      String   @unique @map("shipment_id") @db.Uuid
  invoiceNumber   String   @unique @map("invoice_number")
  paymentIntentId String?  @map("payment_intent_id") @db.Uuid
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("SAR")
  issuedAt        DateTime @map("issued_at")
  payload         Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_invoices")
}

model CarrierRating {
  id           String   @id @default(uuid()) @db.Uuid
  shipmentId   String   @unique @map("shipment_id") @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  fleetOwnerId String   @map("fleet_owner_id") @db.Uuid
  score        Int
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  shipment   Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customer   User       @relation("RatingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)

  @@index([fleetOwnerId])
  @@map("carrier_ratings")
}

model ShipmentStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  shipmentId String         @map("shipment_id") @db.Uuid
  fromStatus ShipmentStatus? @map("from_status")
  toStatus   ShipmentStatus @map("to_status")
  actorId    String?        @map("actor_id") @db.Uuid
  note       String?
  createdAt  DateTime       @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorId], references: [id])

  @@index([shipmentId])
  @@map("shipment_status_history")
}

model ShipmentEvent {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  eventType  String   @map("event_type")
  payload    Json     @default("{}")
  actorId    String?  @map("actor_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorId], references: [id])

  @@index([shipmentId, createdAt])
  @@index([eventType])
  @@map("shipment_events")
}

// ── Pricing ─────────────────────────────────────────────────────────────────

model PricingRule {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  nameAr      String?  @map("name_ar")
  ruleType    String   @map("rule_type")
  config      Json
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  calculations PriceCalculation[]

  @@map("pricing_rules")
}

model PriceCalculation {
  id             String   @id @default(uuid()) @db.Uuid
  shipmentId     String   @unique @map("shipment_id") @db.Uuid
  pricingRuleId  String?  @map("pricing_rule_id") @db.Uuid
  baseAmount     Decimal  @map("base_amount") @db.Decimal(12, 2)
  platformFee    Decimal  @map("platform_fee") @db.Decimal(12, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  currency       String   @default("SAR")
  breakdown      Json     @default("{}")
  calculatedAt   DateTime @default(now()) @map("calculated_at")

  shipment    Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  pricingRule PricingRule? @relation(fields: [pricingRuleId], references: [id])

  @@map("price_calculations")
}

// ── Payments ────────────────────────────────────────────────────────────────

model PaymentIntent {
  id               String              @id @default(uuid()) @db.Uuid
  shipmentId       String              @map("shipment_id") @db.Uuid
  customerId       String              @map("customer_id") @db.Uuid
  amount           Decimal             @db.Decimal(12, 2)
  currency         String              @default("SAR")
  status           PaymentStatus       @default(requires_confirmation)
  provider         PaymentProviderType @default(mock)
  providerIntentId String?             @unique @map("provider_intent_id")
  clientSecret     String?             @map("client_secret")
  metadata         Json                @default("{}")
  failureCode      String?             @map("failure_code")
  failureMessage   String?             @map("failure_message")
  confirmedAt      DateTime?           @map("confirmed_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  shipment Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customer User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events   PaymentEvent[]

  @@index([shipmentId])
  @@index([customerId])
  @@index([status])
  @@map("payment_intents")
}

model PaymentEvent {
  id              String   @id @default(uuid()) @db.Uuid
  paymentIntentId String   @map("payment_intent_id") @db.Uuid
  eventType       String   @map("event_type")
  payload         Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([paymentIntentId, createdAt])
  @@map("payment_events")
}

// ── Wallets ─────────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("SAR")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  payoutRequests PayoutRequest[]

  @@map("wallets")
}

model WalletTransaction {
  id             String                @id @default(uuid()) @db.Uuid
  walletId       String                @map("wallet_id") @db.Uuid
  type           WalletTransactionType
  amount         Decimal               @db.Decimal(14, 2)
  balanceAfter   Decimal               @map("balance_after") @db.Decimal(14, 2)
  referenceType  String?               @map("reference_type")
  referenceId    String?               @map("reference_id") @db.Uuid
  idempotencyKey String                @unique @map("idempotency_key")
  description    String?
  createdAt      DateTime              @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model PayoutRequest {
  id                  String              @id @default(uuid()) @db.Uuid
  walletId            String              @map("wallet_id") @db.Uuid
  userId              String              @map("user_id") @db.Uuid
  amount              Decimal             @db.Decimal(14, 2)
  currency            String              @default("SAR")
  bankDetails         Json                @map("bank_details")
  status              PayoutRequestStatus @default(pending)
  reviewedById        String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt          DateTime?           @map("reviewed_at")
  rejectionReason     String?             @map("rejection_reason")
  walletTransactionId String?             @map("wallet_transaction_id") @db.Uuid
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  wallet     Wallet @relation(fields: [walletId], references: [id])
  user       User   @relation(fields: [userId], references: [id])
  reviewedBy User?  @relation("PayoutReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payout_requests")
}

// ── Tracking ────────────────────────────────────────────────────────────────

model TrackingPoint {
  id         BigInt   @id @default(autoincrement())
  shipmentId String   @map("shipment_id") @db.Uuid
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  speed      Decimal? @db.Decimal(6, 2)
  heading    Decimal? @db.Decimal(5, 2)
  recordedAt DateTime @map("recorded_at")
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, recordedAt])
  @@map("tracking_points")
}

model GeofenceEvent {
  id         String   @id @default(uuid()) @db.Uuid
  shipmentId String   @map("shipment_id") @db.Uuid
  eventType  String   @map("event_type")
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("geofence_events")
}

// ── Truck Marketplace ───────────────────────────────────────────────────────

model TruckListing {
  id                       String                  @id @default(uuid()) @db.Uuid
  fleetOwnerId             String                  @map("fleet_owner_id") @db.Uuid
  vehicleId                String?                 @unique @map("vehicle_id") @db.Uuid
  slug                     String                  @unique
  name                     String
  brand                    String?
  model                    String?
  year                     Int?
  vehicleCategory          VehicleCategory         @map("vehicle_category")
  vehicleType              VehicleType             @map("vehicle_type")
  capacityKg               Decimal?                @map("capacity_kg") @db.Decimal(10, 2)
  capacityCbm              Decimal?                @map("capacity_cbm") @db.Decimal(10, 2)
  lengthM                  Decimal?                @map("length_m") @db.Decimal(6, 2)
  widthM                   Decimal?                @map("width_m") @db.Decimal(6, 2)
  heightM                  Decimal?                @map("height_m") @db.Decimal(6, 2)
  cargoType                CargoType               @default(dry) @map("cargo_type")
  shippingMethod           ShippingMethod          @default(standard) @map("shipping_method")
  crossBorderSupport       Boolean                 @default(false) @map("cross_border_support")
  refrigeratedSupport      Boolean                 @default(false) @map("refrigerated_support")
  hazardousMaterialsSupport Boolean                @default(false) @map("hazardous_materials_support")
  containerTransportSupport Boolean                @default(false) @map("container_transport_support")
  insuranceCoverage        Boolean                 @default(false) @map("insurance_coverage")
  operatingCountries       String[]                @default([]) @map("operating_countries")
  plateNumber              String?                 @map("plate_number")
  videoUrl                 String?                 @map("video_url")
  description              String?
  coverImageUrl            String?                 @map("cover_image_url")
  availabilityStatus       TruckAvailabilityStatus @default(available) @map("availability_status")
  listingStatus            TruckListingStatus      @default(draft) @map("listing_status")
  isFeatured               Boolean                 @default(false) @map("is_featured")
  isListingEnabled         Boolean                 @default(true) @map("is_listing_enabled")
  pricePerKm               Decimal?                @map("price_per_km") @db.Decimal(10, 2)
  dailyRentalPrice         Decimal?                @map("daily_rental_price") @db.Decimal(10, 2)
  weeklyRentalPrice        Decimal?                @map("weekly_rental_price") @db.Decimal(10, 2)
  monthlyRentalPrice       Decimal?                @map("monthly_rental_price") @db.Decimal(10, 2)
  withDriverAvailable      Boolean                 @default(true) @map("with_driver_available")
  withoutDriverAvailable   Boolean                 @default(true) @map("without_driver_available")
  minRentalDays            Int?                    @map("min_rental_days")
  avgRating                Decimal                 @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewCount              Int                     @default(0) @map("review_count")
  completedDeliveries      Int                     @default(0) @map("completed_deliveries")
  viewCount                Int                     @default(0) @map("view_count")
  rejectionReason          String?                 @map("rejection_reason")
  approvedAt               DateTime?               @map("approved_at")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")

  fleetOwner    FleetOwner           @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  images        TruckListingImage[]
  quoteRequests TruckQuoteRequest[]
  reviews       TruckReview[]
  views         MarketplaceView[]
  shipments     Shipment[]
  serviceAreas  TruckListingServiceArea[]

  @@index([fleetOwnerId])
  @@index([listingStatus, isListingEnabled])
  @@index([isFeatured])
  @@index([vehicleCategory])
  @@index([vehicleType])
  @@map("truck_listings")
}

model TruckListingImage {
  id             String   @id @default(uuid()) @db.Uuid
  truckListingId String   @map("truck_listing_id") @db.Uuid
  url            String
  sortOrder      Int      @default(0) @map("sort_order")
  isCover        Boolean  @default(false) @map("is_cover")
  createdAt      DateTime @default(now()) @map("created_at")

  truckListing TruckListing @relation(fields: [truckListingId], references: [id], onDelete: Cascade)

  @@index([truckListingId])
  @@map("truck_listing_images")
}

model TruckQuoteRequest {
  id             String             @id @default(uuid()) @db.Uuid
  truckListingId String             @map("truck_listing_id") @db.Uuid
  customerId     String             @map("customer_id") @db.Uuid
  originCity     String             @map("origin_city")
  originCountry  String             @map("origin_country")
  destCity       String             @map("dest_city")
  destCountry    String             @map("dest_country")
  cargoDetails   String?            @map("cargo_details")
  weightKg       Decimal?           @map("weight_kg") @db.Decimal(10, 2)
  preferredDate  DateTime?          @map("preferred_date")
  status         QuoteRequestStatus @default(pending)
  fleetResponse  String?            @map("fleet_response")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  truckListing TruckListing @relation(fields: [truckListingId], references: [id], onDelete: Cascade)
  customer     User         @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([truckListingId])
  @@index([customerId])
  @@index([status])
  @@map("truck_quote_requests")
}

model TruckReview {
  id                    String   @id @default(uuid()) @db.Uuid
  truckListingId        String   @map("truck_listing_id") @db.Uuid
  customerId            String   @map("customer_id") @db.Uuid
  fleetOwnerId          String   @map("fleet_owner_id") @db.Uuid
  driverId              String?  @map("driver_id") @db.Uuid
  shipmentId            String?  @map("shipment_id") @db.Uuid
  communicationScore    Int      @map("communication_score")
  deliverySpeedScore    Int      @map("delivery_speed_score")
  vehicleConditionScore Int      @map("vehicle_condition_score")
  professionalismScore  Int      @map("professionalism_score")
  overallScore          Int      @map("overall_score")
  comment               String?
  isVisible             Boolean  @default(true) @map("is_visible")
  isModerated           Boolean  @default(false) @map("is_moderated")
  createdAt             DateTime @default(now()) @map("created_at")

  truckListing TruckListing @relation(fields: [truckListingId], references: [id], onDelete: Cascade)
  customer     User         @relation("TruckReviewCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  fleetOwner   FleetOwner   @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)

  @@index([truckListingId])
  @@index([fleetOwnerId])
  @@index([customerId])
  @@map("truck_reviews")
}

model MarketplaceView {
  id             String   @id @default(uuid()) @db.Uuid
  truckListingId String   @map("truck_listing_id") @db.Uuid
  sessionId      String?  @map("session_id")
  viewedAt       DateTime @default(now()) @map("viewed_at")

  truckListing TruckListing @relation(fields: [truckListingId], references: [id], onDelete: Cascade)

  @@index([truckListingId, viewedAt])
  @@map("marketplace_views")
}

// ── Geography (multi-country) ─────────────────────────────────────────────────

model Country {
  code             String   @id @db.Char(2)
  nameEn           String   @map("name_en")
  nameAr           String   @map("name_ar")
  defaultCurrency  String   @default("OMR") @map("default_currency")
  centerLatitude   Decimal  @map("center_latitude") @db.Decimal(10, 7)
  centerLongitude  Decimal  @map("center_longitude") @db.Decimal(10, 7)
  defaultZoom      Int      @default(6) @map("default_zoom")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  regions GeoRegion[]

  @@map("countries")
}

model GeoRegion {
  id          String        @id @default(uuid()) @db.Uuid
  countryCode String        @map("country_code") @db.Char(2)
  type        GeoRegionType
  code        String
  nameEn      String        @map("name_en")
  nameAr      String        @map("name_ar")
  parentId    String?       @map("parent_id") @db.Uuid
  latitude    Decimal?      @db.Decimal(10, 7)
  longitude   Decimal?      @db.Decimal(10, 7)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")

  country              Country                  @relation(fields: [countryCode], references: [code])
  parent               GeoRegion?               @relation("GeoHierarchy", fields: [parentId], references: [id])
  children             GeoRegion[]              @relation("GeoHierarchy")
  truckServiceAreas    TruckListingServiceArea[]
  pickupShipmentReqs   ShipmentRequest[]        @relation("PickupRegion")
  deliveryShipmentReqs ShipmentRequest[]        @relation("DeliveryRegion")

  @@unique([countryCode, code])
  @@index([countryCode, type])
  @@index([parentId])
  @@map("geo_regions")
}

model TruckListingServiceArea {
  truckListingId String @map("truck_listing_id") @db.Uuid
  geoRegionId    String @map("geo_region_id") @db.Uuid

  truckListing TruckListing @relation(fields: [truckListingId], references: [id], onDelete: Cascade)
  geoRegion    GeoRegion    @relation(fields: [geoRegionId], references: [id], onDelete: Cascade)

  @@id([truckListingId, geoRegionId])
  @@map("truck_listing_service_areas")
}

model ShipmentRequest {
  id                  String                @id @default(uuid()) @db.Uuid
  referenceNumber     String                @unique @map("reference_number")
  customerId          String                @map("customer_id") @db.Uuid
  status              ShipmentRequestStatus @default(open)
  pickupAddress       String                @map("pickup_address")
  pickupGeoRegionId   String?               @map("pickup_geo_region_id") @db.Uuid
  pickupLatitude      Decimal?              @map("pickup_latitude") @db.Decimal(10, 7)
  pickupLongitude     Decimal?              @map("pickup_longitude") @db.Decimal(10, 7)
  deliveryAddress     String                @map("delivery_address")
  deliveryGeoRegionId String?               @map("delivery_geo_region_id") @db.Uuid
  deliveryLatitude    Decimal?              @map("delivery_latitude") @db.Decimal(10, 7)
  deliveryLongitude   Decimal?              @map("delivery_longitude") @db.Decimal(10, 7)
  cargoType           CargoType             @default(dry) @map("cargo_type")
  weightKg            Decimal?              @map("weight_kg") @db.Decimal(10, 2)
  preferredDate       DateTime?             @map("preferred_date")
  notes               String?
  requiredVehicleType VehicleType?          @map("required_vehicle_type")
  requiresRefrigerated Boolean              @default(false) @map("requires_refrigerated")
  requiresCrossBorder  Boolean              @default(false) @map("requires_cross_border")
  requiresContainer    Boolean              @default(false) @map("requires_container")
  convertedShipmentId  String?               @map("converted_shipment_id") @db.Uuid
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  customer        User                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pickupRegion    GeoRegion?               @relation("PickupRegion", fields: [pickupGeoRegionId], references: [id])
  deliveryRegion  GeoRegion?               @relation("DeliveryRegion", fields: [deliveryGeoRegionId], references: [id])
  matches         ShipmentRequestMatch[]

  @@index([customerId])
  @@index([status])
  @@map("shipment_requests")
}

model ShipmentRequestMatch {
  id                String   @id @default(uuid()) @db.Uuid
  shipmentRequestId String   @map("shipment_request_id") @db.Uuid
  fleetOwnerId      String   @map("fleet_owner_id") @db.Uuid
  truckListingId    String?  @map("truck_listing_id") @db.Uuid
  notifiedAt        DateTime @default(now()) @map("notified_at")

  shipmentRequest ShipmentRequest @relation(fields: [shipmentRequestId], references: [id], onDelete: Cascade)
  fleetOwner      FleetOwner      @relation(fields: [fleetOwnerId], references: [id], onDelete: Cascade)

  @@unique([shipmentRequestId, fleetOwnerId])
  @@index([fleetOwnerId])
  @@map("shipment_request_matches")
}

// ── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  titleEn   String              @map("title_en")
  titleAr   String              @map("title_ar")
  bodyEn    String              @map("body_en")
  bodyAr    String              @map("body_ar")
  data      Json                @default("{}")
  isRead    Boolean             @default(false) @map("is_read")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ── Platform ────────────────────────────────────────────────────────────────

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
