{
  "name": "transit-logistic",
  "version": "0.0.0",
  "private": true,
  "description": "Transit Logistic — multi-sided logistics platform monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "postinstall": "pnpm --filter @transit-logistic/api db:generate",
    "db:generate": "pnpm --filter @transit-logistic/api exec prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "pnpm --filter @transit-logistic/api exec prisma migrate dev",
    "db:push": "pnpm --filter @transit-logistic/api exec prisma db push",
    "db:studio": "pnpm --filter @transit-logistic/api exec prisma studio",
    "db:reset-postgres": "powershell -ExecutionPolicy Bypass -File scripts/reset-postgres-dev.ps1",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml --env-file infra/docker/.env up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml --env-file infra/docker/.env down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml --env-file infra/docker/.env logs -f",
    "redis:start": "powershell -ExecutionPolicy Bypass -File scripts/start-redis.ps1",
    "redis:install": "powershell -ExecutionPolicy Bypass -File scripts/install-redis.ps1",
    "verify:production": "node scripts/verify-production.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
